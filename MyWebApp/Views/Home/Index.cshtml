@model List<MyWebApp.Models.Ticket>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">Dashboard de Tickets</h1>
        <p class="text-muted fs-5">
            Consulta y gestión de requerimientos almacenados en Supabase.
        </p>
        <span class="badge bg-secondary px-3 py-2 fs-6">
            Total Tickets: @(Model?.Count() ?? 0)
        </span>
    </div>

    @await Html.PartialAsync("_TicketTable", Model)
</div>